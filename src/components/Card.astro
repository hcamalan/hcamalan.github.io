---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  href: string;
  title: string;
  description: string;
  image: ImageMetadata;
  imageAlt: string;
  meta?: string;
  tags?: string[];
  external?: boolean;
  secondaryHref?: string;
  secondaryLabel?: string;
}

const {
  href,
  title,
  description,
  image,
  imageAlt,
  meta,
  tags = [],
  external = false,
  secondaryHref,
  secondaryLabel,
} = Astro.props;
---

<div class="group flex flex-col overflow-hidden rounded-2xl border border-line bg-bg-2 reveal">
  <a
    href={href}
    target={external ? '_blank' : undefined}
    rel={external ? 'noopener' : undefined}
    class="block transition-transform duration-300 hover:-translate-y-1"
  >
    <div class="relative aspect-[16/10] overflow-hidden">
      <Image
        src={image}
        alt={imageAlt}
        class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
        widths={[400, 800]}
        sizes="(min-width: 768px) 33vw, 100vw"
      />
    </div>

    <div class="flex flex-col gap-3 p-6 pb-4">
      {meta && <span class="font-mono text-[11px] uppercase tracking-widest text-ink-3">{meta}</span>}
      <h3 class="font-display text-xl font-semibold text-ink">
        {title}
        {external && (
          <span aria-hidden="true" class="ml-1 inline-block text-ink-3 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5">
            ↗
          </span>
        )}
      </h3>
      <p class="text-sm leading-relaxed text-ink-2">{description}</p>
    </div>
  </a>

  <div class="flex flex-1 flex-col justify-end gap-4 px-6 pb-6">
    {
      tags.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {tags.map((tag) => (
            <span class="rounded-full border border-line px-3 py-1 font-mono text-[11px] uppercase tracking-wide text-ink-3">{tag}</span>
          ))}
        </div>
      )
    }

    {
      secondaryHref && (
        <a href={secondaryHref} target="_blank" rel="noopener" class="font-mono text-[11px] uppercase tracking-widest text-ink-3 underline decoration-line underline-offset-4 hover:text-accent-ink hover:decoration-accent">
          {secondaryLabel ?? 'View source ↗'}
        </a>
      )
    }
  </div>
</div>
