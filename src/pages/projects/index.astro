---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/Card.astro';
import { projects } from '../../data/projects';

const statusLabel: Record<string, string> = {
  live: 'Live',
  'in-progress': 'In progress',
  planned: 'Planned',
};
---

<BaseLayout title="Projects" description="Things Hüseyin Camalan has built, starting with ChronoKanban.">
  <section class="px-6 pb-24 pt-40 sm:px-10">
    <div class="mx-auto max-w-5xl">
      <p class="kicker mb-6">Projects</p>
      <h1 class="font-display text-4xl font-semibold leading-tight sm:text-5xl">Things I've built</h1>
      <p class="mt-6 max-w-xl text-lg text-ink-2">
        Mostly side projects born out of wanting a tool that didn't quite exist yet. More will show up here over time.
      </p>

      <div class="mt-14 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          projects.map((project) => (
            <Card
              href={project.liveUrl ?? project.repoUrl ?? '#'}
              title={project.title}
              description={project.description}
              image={project.image}
              imageAlt={`${project.title} preview`}
              meta={statusLabel[project.status]}
              tags={project.tags}
              external
              secondaryHref={project.liveUrl ? project.repoUrl : undefined}
              secondaryLabel="View source ↗"
            />
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
