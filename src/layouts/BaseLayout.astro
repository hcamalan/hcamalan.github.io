---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = 'Hüseyin Camalan — IT transformation consultant based in Berlin.',
  image,
} = Astro.props;

const pageTitle = title === 'Hüseyin Camalan' ? title : `${title} — Hüseyin Camalan`;
const ogImage = image ? new URL(image, Astro.site).toString() : undefined;
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Hüseyin Camalan" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.toString()} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <link rel="canonical" href={Astro.url.toString()} />
    <link rel="alternate" type="application/rss+xml" title="Hüseyin Camalan — Blog" href="/rss.xml" />
    <link
      rel="icon"
      href="data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'><rect width='64' height='64' rx='14' fill='%23111827'/><text x='50%25' y='58%25' text-anchor='middle' font-family='Arial, sans-serif' font-weight='700' font-size='32' fill='white'>H</text></svg>"
    />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <script is:inline>
      (function () {
        var KEY = 'hc-theme';
        var t;
        try {
          t = localStorage.getItem(KEY);
        } catch (_) {}
        if (!t) t = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
  </head>
  <body class="bg-bg text-ink font-sans antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      const THEME_KEY = 'hc-theme';
      function setTheme(t: string) {
        document.documentElement.setAttribute('data-theme', t);
        try {
          localStorage.setItem(THEME_KEY, t);
        } catch (_) {}
      }
      document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
          setTheme(next);
        });
      });

      let io: IntersectionObserver | undefined;
      function wireReveals() {
        io?.disconnect();
        io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('in');
                io?.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
        );
        document.querySelectorAll('.reveal').forEach((el) => {
          if (!el.classList.contains('in')) io?.observe(el);
        });
      }
      wireReveals();

      const header = document.querySelector('[data-site-header]');
      const onScroll = () => header?.classList.toggle('scrolled', window.scrollY > 10);
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    </script>
  </body>
</html>
